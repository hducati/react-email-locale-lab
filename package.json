{
  "name": "react-email-locale-lab",
  "version": "0.4.1",
  "description": "Real-time multi-language previews for React Email templates.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/adapters/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "./dist/styles.css"
  ],
  "keywords": [
    "react-email",
    "email",
    "i18n",
    "localization",
    "preview"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:lib",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "build:demo": "tsc -b && vite build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "biome:check": "biome check .",
    "test": "vitest run --maxWorkers=1",
    "check": "pnpm biome:check && pnpm test && pnpm build",
    "pack:dry-run": "pnpm build && npm pack --dry-run",
    "prepublishOnly": "pnpm check"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^6.9.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.11.0"
}
