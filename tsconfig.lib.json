{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["vite/client"]
  },
  "include": [
    "src/index.ts",
    "src/App.tsx",
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/adapters/**/*.ts",
    "src/core/**/*.ts"
  ],
  "exclude": ["src/**/*.test.ts"]
}
